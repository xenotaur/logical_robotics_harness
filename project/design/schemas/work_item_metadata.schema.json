{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://logicalrobotics.dev/lrh/schema/work_item_metadata.schema.json",
  "title": "LRH Work Item Metadata (First Pass)",
  "description": "Frontmatter metadata contract for work-item status bucket policy.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "status",
    "created_on",
    "updated_on"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "active",
        "resolved",
        "abandoned"
      ]
    },
    "blocked": {
      "type": "boolean",
      "default": false
    },
    "blocked_reason": {
      "type": "string",
      "minLength": 1
    },
    "created_on": {
      "type": "string",
      "format": "date"
    },
    "updated_on": {
      "type": "string",
      "format": "date"
    },
    "resolution": {
      "type": "string",
      "minLength": 1
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "superseded_by": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "blocked": {
            "const": true
          }
        },
        "required": [
          "blocked"
        ]
      },
      "then": {
        "required": [
          "blocked_reason"
        ],
        "properties": {
          "status": {
            "const": "active"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": [
              "resolved",
              "abandoned"
            ]
          }
        },
        "required": [
          "status"
        ]
      },
      "then": {
        "required": [
          "resolution"
        ]
      }
    }
  ]
}
