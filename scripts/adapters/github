#!/usr/bin/env python3
"""Thin wrapper to LRH github CLI with legacy argument normalization."""

from __future__ import annotations

import sys

from lrh.cli import github
from lrh.integrations.github import pr_ref


def _normalize(argv: list[str]) -> list[str]:
    parts = list(argv)
    if parts and parts[0] == "pull":
        parts = parts[1:]
    if parts and parts[0] == "submitted":
        parts[0] = "comments"
    if parts and parts[0] == "reviews":
        parts[0] = "comments"
    if parts and parts[0] == "unresolved":
        parts[0] = "unresolved"

    state = "unresolved"
    if "--state" in parts:
        idx = parts.index("--state")
        if idx + 1 < len(parts):
            state = parts[idx + 1]
        del parts[idx : idx + 2]

    if len(parts) >= 3 and parts[1].startswith("http"):
        ref = pr_ref.parse_pull_request_url(parts[1])
        return [parts[0], f"{ref.owner}/{ref.repo}", str(ref.number)]

    if len(parts) >= 3:
        kind = parts[0]
        if kind == "threads" and state == "unresolved":
            kind = "unresolved"
        return [kind, parts[1], parts[2]]
    return parts


if __name__ == "__main__":
    raise SystemExit(
        github.run_github_cli(_normalize(sys.argv[1:]), prog="scripts/adapters/github")
    )
