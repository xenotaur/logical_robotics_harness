#!/usr/bin/env bash
set -euo pipefail

shell_name="${SHELL##*/}"
if [[ -n "${BASH_VERSION-}" ]]; then
  shell_name="bash"
elif [[ -n "${ZSH_VERSION-}" ]]; then
  shell_name="zsh"
fi

echo "Detected shell: ${shell_name}"
echo
echo "To enable completion:"
if [[ "${shell_name}" == "zsh" ]]; then
  echo '  eval "$(register-python-argcomplete --shell zsh lrh)"'
else
  echo '  eval "$(register-python-argcomplete lrh)"'
fi
echo
echo "To persist, add this to your shell config:"
echo "  ~/.bashrc or ~/.zshrc"
echo
echo "Install dependency (if needed):"
echo "  pip install -e '.[completion]'"
