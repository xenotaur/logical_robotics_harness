#!/usr/bin/env python3
"""Compatibility wrapper for legacy prompt labeling script path."""

from __future__ import annotations

import os
import pathlib
import shutil
import subprocess
import sys


def _run(argv: list[str]) -> int:
    lrh_executable = shutil.which("lrh")
    if lrh_executable:
        completed = subprocess.run([lrh_executable, "prompt", "label", *argv], check=False)
        return completed.returncode

    repo_root = pathlib.Path(__file__).resolve().parents[2]
    env = os.environ.copy()
    src_path = str(repo_root / "src")
    existing_pythonpath = env.get("PYTHONPATH", "")
    env["PYTHONPATH"] = (
        f"{src_path}{os.pathsep}{existing_pythonpath}" if existing_pythonpath else src_path
    )
    completed = subprocess.run(
        [sys.executable, "-m", "lrh.cli.main", "prompt", "label", *argv],
        check=False,
        cwd=str(repo_root),
        env=env,
    )
    return completed.returncode


if __name__ == "__main__":
    raise SystemExit(_run(sys.argv[1:]))
