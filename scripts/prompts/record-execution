#!/usr/bin/env python3
"""Create LRH execution record markdown files."""

import argparse
import datetime
import pathlib
import re


VALID_STATUSES = {
    "planned",
    "in_progress",
    "landed",
    "failed",
    "reverted",
    "superseded",
}


def _normalize_slug(value: str) -> str:
    slug = value.strip().lower()
    slug = re.sub(r"[^a-z0-9]+", "-", slug)
    slug = re.sub(r"-+", "-", slug).strip("-")
    if not slug:
        raise ValueError("slug must contain at least one alphanumeric character")
    return slug


def _slug_upper_underscore(slug: str) -> str:
    return slug.replace("-", "_").upper()


def _build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Create execution-record markdown files.")
    parser.add_argument("--prompt-id", required=True, help="Prompt ID for this execution")
    parser.add_argument("--work-item", default="AD_HOC", help="Work item ID (default: AD_HOC)")
    parser.add_argument("--slug", required=True, help="Execution slug")
    parser.add_argument("--status", default="planned", choices=sorted(VALID_STATUSES))
    parser.add_argument("--rerun-of", default="", help="Optional prior execution_id")
    parser.add_argument("--pr", default="", help="Optional PR reference")
    parser.add_argument("--commit", default="", help="Optional commit SHA")
    parser.add_argument(
        "--output-root",
        default="project/executions",
        help="Execution records root (default: project/executions)",
    )
    parser.add_argument("--dry-run", action="store_true", help="Print content without writing")
    parser.add_argument("--force", action="store_true", help="Overwrite file if it exists")
    return parser


def _render_content(
    execution_id: str,
    prompt_id: str,
    work_item: str,
    status: str,
    rerun_of: str,
    pr: str,
    commit: str,
    created_at: str,
) -> str:
    return (
        "---\n"
        f"execution_id: {execution_id}\n"
        f"prompt_id: {prompt_id}\n"
        f"work_item: {work_item}\n"
        f"status: {status}\n"
        f"rerun_of: {rerun_of}\n"
        f"pr: {pr}\n"
        f"commit: {commit}\n"
        f"created_at: {created_at}\n"
        "---\n\n"
        "# Summary\n\n"
        "TODO: Briefly summarize the intended prompt-driven work.\n\n"
        "# Result\n\n"
        "TODO: Fill in what happened.\n\n"
        "# Validation\n\n"
        "TODO: List tests or checks run.\n\n"
        "# Follow-up\n\n"
        "TODO: List deferred work.\n"
    )


def main() -> int:
    parser = _build_parser()
    args = parser.parse_args()

    try:
        slug = _normalize_slug(args.slug)
    except ValueError as error:
        parser.error(str(error))

    now = datetime.datetime.now(datetime.timezone.utc).astimezone()
    work_item = args.work_item.strip() or "AD_HOC"
    timestamp_for_id = now.strftime("%Y_%m_%d_%H_%M_%S")
    slug_upper = _slug_upper_underscore(slug)

    execution_id = f"{timestamp_for_id}_{slug_upper}"
    execution_dir = pathlib.Path(args.output_root) / work_item
    output_file = execution_dir / f"{execution_id}.md"
    created_at = now.isoformat(timespec="seconds")

    content = _render_content(
        execution_id=execution_id,
        prompt_id=args.prompt_id,
        work_item=work_item,
        status=args.status,
        rerun_of=args.rerun_of,
        pr=args.pr,
        commit=args.commit,
        created_at=created_at,
    )

    if args.dry_run:
        print(f"output_file: {output_file.as_posix()}")
        print(content, end="")
        return 0

    execution_dir.mkdir(parents=True, exist_ok=True)
    if output_file.exists() and not args.force:
        parser.error(f"output file already exists: {output_file}")

    output_file.write_text(content, encoding="utf-8")
    print(f"wrote: {output_file.as_posix()}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
